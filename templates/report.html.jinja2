<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ paper.title }} — ppagent Report</title>
<style>
  :root {
    --primary: #2563eb;
    --primary-dark: #1e40af;
    --text: #1f2937;
    --text-light: #6b7280;
    --bg: #ffffff;
    --bg-alt: #f9fafb;
    --border: #e5e7eb;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    max-width: 920px; margin: 0 auto; padding: 2rem 1.5rem;
    line-height: 1.7; color: var(--text); background: var(--bg);
  }
  h1 { font-size: 1.75rem; border-bottom: 3px solid var(--primary); padding-bottom: 0.75rem; margin-bottom: 1rem; }
  h2 { color: var(--primary-dark); margin-top: 2.5rem; margin-bottom: 0.75rem; font-size: 1.35rem; border-bottom: 1px solid var(--border); padding-bottom: 0.35rem; }
  h3 { color: var(--primary-dark); margin-top: 1.5rem; margin-bottom: 0.5rem; font-size: 1.1rem; }
  p { margin-bottom: 0.75rem; }
  blockquote {
    border-left: 4px solid var(--primary); margin: 1rem 0; padding: 0.75rem 1rem;
    background: var(--bg-alt); border-radius: 0 6px 6px 0; color: var(--text-light);
  }
  table { border-collapse: collapse; width: 100%; margin: 1rem 0; }
  th, td { border: 1px solid var(--border); padding: 0.5rem 0.75rem; text-align: left; }
  th { background: var(--bg-alt); font-weight: 600; }
  ul, ol { margin: 0.5rem 0 0.75rem 1.5rem; }
  li { margin-bottom: 0.25rem; }
  a { color: var(--primary); text-decoration: none; }
  a:hover { text-decoration: underline; }
  hr { border: none; border-top: 1px solid var(--border); margin: 2rem 0; }
  code { background: var(--bg-alt); padding: 0.15rem 0.35rem; border-radius: 3px; font-size: 0.9em; }
  pre { background: var(--bg-alt); padding: 1rem; border-radius: 6px; overflow-x: auto; margin: 1rem 0; }
  pre code { background: none; padding: 0; }
  .footer { margin-top: 3rem; padding-top: 1rem; border-top: 1px solid var(--border); color: var(--text-light); font-size: 0.85rem; }
  .meta-table { font-size: 0.95rem; }
  .severity-high { color: #dc2626; font-weight: 700; }
  .severity-medium { color: #d97706; font-weight: 600; }
  .severity-low { color: #6b7280; }
  
  .pricing-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-top: 1.5rem;
    margin-bottom: 2rem;
  }
  @media (min-width: 768px) {
    .pricing-container.has-cost {
      grid-template-columns: 3fr 2fr;
    }
  }
  .price-table-wrapper h3, .cost-card h3 {
    font-size: 1.1rem;
    color: var(--primary-dark);
    margin-bottom: 0.75rem;
  }
  .price-table {
    font-size: 0.85rem;
    border-collapse: collapse;
    width: 100%;
  }
  .price-table th {
    background: var(--bg-alt);
    font-weight: 600;
  }
  .price-table td, .price-table th {
    border: 1px solid var(--border);
    padding: 0.5rem 0.6rem;
  }
  .price-val {
    font-family: monospace;
    text-align: right;
  }
  .cost-card {
    background: linear-gradient(135deg, #f0f4ff 0%, #e0ebff 100%);
    border: 1px solid #bfdbfe;
    border-radius: 12px;
    padding: 1.5rem;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
    align-self: start;
  }
  .cost-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid #bfdbfe;
    padding-bottom: 0.75rem;
    margin-bottom: 1rem;
  }
  .cost-card-header h3 {
    margin-bottom: 0;
    color: #1e3a8a;
  }
  .model-badge {
    background: #3b82f6;
    color: white;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.2rem 0.6rem;
    border-radius: 9999px;
    text-transform: uppercase;
  }
  .cost-card-body {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .cost-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.95rem;
  }
  .cost-label {
    color: #4b5563;
  }
  .cost-value {
    font-weight: 500;
    color: #111827;
  }
  .cost-sub {
    font-size: 0.85rem;
    color: #6b7280;
    font-family: monospace;
  }
  .cost-divider {
    border-top: 1px solid #bfdbfe;
    margin: 0.5rem 0;
  }
  .total-cost-row {
    font-size: 1.1rem;
    font-weight: 700;
  }
  .total-cost-row .cost-label {
    color: #1e3a8a;
    font-weight: 700;
  }
  .total-price {
    color: #2563eb;
    font-family: monospace;
    font-size: 1.2rem;
  }
</style>
<script>
  window.MathJax = {
    tex: {
      inlineMath: [['$', '$'], ['\\(', '\\)']],
      displayMath: [['$$', '$$'], ['\\[', '\\]']],
      processEscapes: true,
      processEnvironments: true
    },
    options: {
      skipHtmlTags: ['script', 'noscript', 'style', 'textarea', 'pre']
    }
  };
</script>
<script src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-chtml.js" id="MathJax-script" async></script>
</head>
<body>

<h1>{{ paper.title }}</h1>

<blockquote><strong>TL;DR</strong>: {{ tldr.content }}</blockquote>

<table class="meta-table">
  <tr><th>Field</th><th>Value</th></tr>
  <tr><td><strong>Paper</strong></td><td><a href="{{ paper.arxiv_url }}">arXiv:{{ paper.id }}</a></td></tr>
  <tr><td><strong>HuggingFace</strong></td><td><a href="{{ paper.hf_url }}">Link</a></td></tr>
  <tr><td><strong>Published</strong></td><td>{{ paper.published_at.strftime('%Y-%m-%d') if paper.published_at else 'Unknown' }}</td></tr>
  <tr><td><strong>Authors</strong></td><td>{{ paper.authors | join(', ') }}</td></tr>
  <tr><td><strong>Affiliations</strong></td><td>{{ affiliations | join(', ') or 'N/A' }}</td></tr>
  <tr><td><strong>Keywords</strong></td><td>{{ keywords | join(', ') or 'N/A' }}</td></tr>
</table>

<h2>Benchmarks</h2>
<div>{{ benchmarks.content | markdown }}</div>

<h2>Previous Work &amp; Limitations</h2>
<div>{{ previous_works.content | markdown }}</div>

{% if finder_narrative %}
<h3>Related Work Landscape</h3>
<div>{{ finder_narrative | markdown }}</div>
{% endif %}

<h2>Method</h2>
<div>{{ method.content | markdown }}</div>

<h2>Performance Evaluation</h2>
<div>{{ evaluation.content | markdown }}</div>

<h2>Critical Analysis</h2>
<div>{{ critique.content | markdown }}</div>

<h2>Related Papers</h2>
{% if related_works %}
<ul>
{% for rp in related_works %}
  <li><a href="{{ rp.arxiv_url }}">{{ rp.title }}</a> ({{ rp.id }})</li>
{% endfor %}
</ul>
{% else %}
<p>No related papers found.</p>
{% endif %}

<h2>LLM Reference Pricing &amp; Generation Cost</h2>

<div class="pricing-container {% if cost_report %}has-cost{% endif %}">
  <div class="price-table-wrapper">
    <h3>Official LLM Price Table (per 1M Tokens)</h3>
    <table class="price-table">
      <thead>
        <tr>
          <th>Provider</th>
          <th>Representative Model</th>
          <th>Input Price (USD)</th>
          <th>Output Price (USD)</th>
        </tr>
      </thead>
      <tbody>
        {% for key, val in price_table.items() %}
        <tr>
          <td><strong>{{ val.provider }}</strong></td>
          <td><code>{{ val.model }}</code></td>
          <td class="price-val">${{ "%.3f"|format(val.input_price) }}</td>
          <td class="price-val">${{ "%.3f"|format(val.output_price) }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  {% if cost_report %}
  <div class="cost-card">
    <div class="cost-card-header">
      <h3>Generation Cost Breakdown</h3>
      <span class="model-badge">{{ cost_report.provider }}</span>
    </div>
    <div class="cost-card-body">
      <div class="cost-row">
        <span class="cost-label">Model Used</span>
        <span class="cost-value"><code>{{ cost_report.model }}</code></span>
      </div>
      <div class="cost-row">
        <span class="cost-label">Input Tokens</span>
        <span class="cost-value">{{ usage.prompt_tokens }} <span class="cost-sub">(${{ "%.6f"|format(cost_report.input_cost) }})</span></span>
      </div>
      <div class="cost-row">
        <span class="cost-label">Output Tokens</span>
        <span class="cost-value">{{ usage.completion_tokens }} <span class="cost-sub">(${{ "%.6f"|format(cost_report.output_cost) }})</span></span>
      </div>
      <div class="cost-row">
        <span class="cost-label">Total Tokens</span>
        <span class="cost-value">{{ usage.total_tokens }}</span>
      </div>
      <div class="cost-divider"></div>
      <div class="cost-row total-cost-row">
        <span class="cost-label">Total Cost</span>
        <span class="cost-value total-price">${{ "%.6f"|format(cost_report.total_cost) }}</span>
      </div>
    </div>
  </div>
  {% endif %}
</div>

<div class="footer">
  Generated by <strong>ppagent</strong> on {{ generated_at.strftime('%Y-%m-%d %H:%M') }} using {{ model_used }}
</div>

</body>
</html>
