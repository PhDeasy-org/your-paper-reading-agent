<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ paper.title }} — ppagent Report</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --font-heading: 'Outfit', -apple-system, BlinkMacSystemFont, sans-serif;
    --font-body: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    
    /* Light Theme Settings */
    --bg-app: #f8fafc;
    --bg-card: #ffffff;
    --bg-sidebar: #ffffff;
    --border: #e2e8f0;
    
    --text-main: #0f172a;
    --text-muted: #475569;
    --text-light: #64748b;
    
    --primary: #4f46e5;
    --primary-hover: #4338ca;
    --primary-light: #e0e7ff;
    --primary-gradient: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
    
    --success: #10b981;
    --success-light: #d1fae5;
    --warning: #f59e0b;
    --warning-light: #fef3c7;
    --danger: #ef4444;
    --danger-light: #fee2e2;
    
    --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
    --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
    --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.05), 0 4px 6px -4px rgba(0, 0, 0, 0.03);
    
    --code-bg: #f1f5f9;
    --tldr-bg: rgba(79, 70, 229, 0.05);
  }

  [data-theme="dark"] {
    /* Dark Theme Settings */
    --bg-app: #090d16;
    --bg-card: #111827;
    --bg-sidebar: #0f172a;
    --border: #1f2937;
    
    --text-main: #f3f4f6;
    --text-muted: #9ca3af;
    --text-light: #6b7280;
    
    --primary: #6366f1;
    --primary-hover: #4f46e5;
    --primary-light: rgba(99, 102, 241, 0.15);
    --primary-gradient: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
    
    --success: #10b981;
    --success-light: rgba(16, 185, 129, 0.15);
    --warning: #f59e0b;
    --warning-light: rgba(245, 158, 11, 0.15);
    --danger: #ef4444;
    --danger-light: rgba(239, 68, 68, 0.15);
    
    --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.5);
    --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.3), 0 2px 4px -2px rgba(0, 0, 0, 0.3);
    --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.4), 0 4px 6px -4px rgba(0, 0, 0, 0.4);
    
    --code-bg: #1e293b;
    --tldr-bg: rgba(99, 102, 241, 0.08);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  
  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--font-body);
    background-color: var(--bg-app);
    color: var(--text-main);
    line-height: 1.7;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  @media (min-width: 1024px) {
    body {
      flex-direction: row;
    }
    .sidebar {
      width: 320px;
      height: 100vh;
      position: fixed;
      top: 0;
      left: 0;
      overflow-y: auto;
      border-right: 1px solid var(--border);
    }
    .main-content {
      margin-left: 320px;
      flex: 1;
      padding: 3rem 4rem;
      max-width: 1000px;
    }
  }

  @media (max-width: 1023px) {
    .sidebar {
      width: 100%;
      border-bottom: 1px solid var(--border);
      padding: 2rem 1.5rem;
    }
    .main-content {
      width: 100%;
      padding: 2.5rem 1.5rem;
    }
  }

  /* Sidebar Styling */
  .sidebar {
    background-color: var(--bg-sidebar);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 2rem 1.5rem;
    gap: 2rem;
  }

  .sidebar-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .logo-icon {
    background: var(--primary-gradient);
    color: white;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-sm);
  }

  .logo-text {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    background: var(--primary-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .logo-tag {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    background: var(--primary-light);
    color: var(--primary);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    letter-spacing: 0.05em;
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    flex-grow: 1;
    margin-top: 1rem;
  }

  .nav-section-title {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-light);
    font-weight: 700;
    margin-bottom: 0.5rem;
    padding-left: 0.5rem;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0.8rem;
    color: var(--text-muted);
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    border-radius: 8px;
    transition: all 0.2s ease;
  }

  .nav-link:hover {
    color: var(--primary);
    background-color: var(--primary-light);
  }

  .nav-link.active {
    color: white;
    background: var(--primary-gradient);
    font-weight: 600;
    box-shadow: var(--shadow-sm);
  }

  .nav-icon {
    flex-shrink: 0;
    opacity: 0.8;
  }
  
  .nav-link.active .nav-icon {
    opacity: 1;
  }

  .sidebar-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }

  .theme-control {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  .control-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-muted);
  }

  .theme-toggle {
    background: var(--bg-app);
    border: 1px solid var(--border);
    color: var(--text-main);
    padding: 0.5rem;
    border-radius: 8px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    width: 36px;
    height: 36px;
  }

  .theme-toggle:hover {
    background: var(--primary-light);
    color: var(--primary);
    border-color: rgba(79, 70, 229, 0.2);
  }

  .sun-icon {
    display: none;
  }
  .moon-icon {
    display: block;
  }
  [data-theme="dark"] .sun-icon {
    display: block;
  }
  [data-theme="dark"] .moon-icon {
    display: none;
  }

  /* Main Content Area */
  .main-header {
    margin-bottom: 2.5rem;
  }

  .main-header h1 {
    font-family: var(--font-heading);
    font-size: 2.25rem;
    font-weight: 800;
    line-height: 1.25;
    color: var(--text-main);
    letter-spacing: -0.03em;
    margin-bottom: 0.75rem;
  }

  .paper-subtitle {
    font-size: 1.05rem;
    color: var(--text-light);
    font-weight: 500;
  }

  /* TLDR Card */
  .tldr-card {
    background: var(--tldr-bg);
    border-left: 4px solid var(--primary);
    border-radius: 0 16px 16px 0;
    padding: 1.75rem 2rem;
    margin-bottom: 2.5rem;
    position: relative;
    box-shadow: var(--shadow-sm);
  }

  .tldr-badge {
    position: absolute;
    top: -10px;
    left: 20px;
    background: var(--primary-gradient);
    color: white;
    font-size: 0.75rem;
    font-weight: 800;
    padding: 0.2rem 0.75rem;
    border-radius: 20px;
    letter-spacing: 0.05em;
    box-shadow: var(--shadow-sm);
  }

  .tldr-content {
    font-size: 1.05rem;
    font-weight: 500;
    line-height: 1.6;
    color: var(--text-main);
  }

  /* Content Cards */
  .content-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem;
    margin-bottom: 2rem;
    box-shadow: var(--shadow-sm);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .content-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .content-card h2 {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text-main);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    position: relative;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .heading-icon {
    color: var(--primary);
    flex-shrink: 0;
  }

  /* Info Grid Styling */
  .info-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 640px) {
    .info-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .info-item {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .info-item.full-width {
    grid-column: 1 / -1;
  }
  .info-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-light);
    font-weight: 600;
  }
  .info-value {
    color: var(--text-main);
    font-size: 0.95rem;
  }
  .btn-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.8rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.85rem;
    text-decoration: none;
    transition: all 0.2s ease;
    align-self: start;
  }
  .arxiv-badge {
    background: var(--primary-light);
    color: var(--primary);
    border: 1px solid rgba(79, 70, 229, 0.15);
  }
  .arxiv-badge:hover {
    background: var(--primary);
    color: white;
  }
  .hf-badge {
    background: #fef3c7;
    color: #d97706;
    border: 1px solid rgba(217, 119, 6, 0.15);
  }
  .hf-badge:hover {
    background: #d97706;
    color: white;
  }
  .tags-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .tag {
    font-size: 0.8rem;
    padding: 0.25rem 0.6rem;
    border-radius: 6px;
    font-weight: 500;
    border: 1px solid var(--border);
  }
  .keyword-tag {
    background: var(--bg-app);
    color: var(--text-muted);
  }
  .affiliation-tag {
    background: rgba(16, 185, 129, 0.08);
    color: #10b981;
    border-color: rgba(16, 185, 129, 0.15);
  }
  .authors-list {
    color: var(--text-muted);
    line-height: 1.5;
  }

  /* Markdown Body Rendering Styling */
  .markdown-body {
    font-size: 0.975rem;
    line-height: 1.7;
    color: var(--text-muted);
  }

  /* Paper Figure (Method pipeline diagram) */
  .paper-figure {
    margin: 0 0 1.75rem 0;
    background: var(--bg-app);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }
  .paper-figure img {
    display: block;
    width: 100%;
    height: auto;
    max-height: 640px;
    object-fit: contain;
    background: #ffffff;
  }
  [data-theme="dark"] .paper-figure img {
    /* Most figures have white backgrounds; keep them readable on dark theme */
    background: #ffffff;
  }
  .paper-figure figcaption {
    padding: 0.75rem 1.1rem;
    font-size: 0.85rem;
    color: var(--text-light);
    line-height: 1.5;
    border-top: 1px solid var(--border);
  }
  .markdown-body p {
    margin-bottom: 1.25rem;
  }
  .markdown-body p:last-child {
    margin-bottom: 0;
  }
  .markdown-body ul, .markdown-body ol {
    margin-left: 1.5rem;
    margin-bottom: 1.25rem;
  }
  .markdown-body li {
    margin-bottom: 0.5rem;
  }
  .markdown-body blockquote {
    border-left: 4px solid var(--primary);
    background: var(--tldr-bg);
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
    border-radius: 0 12px 12px 0;
    color: var(--text-muted);
  }
  .markdown-body table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.9rem;
  }
  .markdown-body th, .markdown-body td {
    padding: 0.75rem 1rem;
    border: 1px solid var(--border);
    text-align: left;
  }
  .markdown-body th {
    background: var(--bg-app);
    font-weight: 600;
    color: var(--text-main);
  }
  .markdown-body tr:nth-child(even) {
    background: rgba(0, 0, 0, 0.02);
  }
  [data-theme="dark"] .markdown-body tr:nth-child(even) {
    background: rgba(255, 255, 255, 0.02);
  }
  .markdown-body pre {
    background: var(--code-bg);
    border: 1px solid var(--border);
    padding: 1.25rem;
    border-radius: 12px;
    overflow-x: auto;
    margin: 1.5rem 0;
    position: relative;
  }
  .markdown-body code {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.85em;
    background: var(--code-bg);
    padding: 0.2rem 0.4rem;
    border-radius: 6px;
    color: var(--primary);
  }
  .markdown-body pre code {
    padding: 0;
    background: none;
    font-size: 0.9rem;
    color: var(--text-main);
  }

  /* Critique Badges */
  .badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.15rem 0.5rem;
    border-radius: 9999px;
    margin-right: 0.5rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .badge-high {
    background-color: var(--danger-light);
    color: #ef4444;
    border: 1px solid rgba(239, 68, 68, 0.2);
  }
  .badge-medium {
    background-color: var(--warning-light);
    color: #d97706;
    border: 1px solid rgba(217, 119, 6, 0.2);
  }
  .badge-low {
    background-color: var(--border);
    color: var(--text-light);
    border: 1px solid rgba(100, 116, 139, 0.2);
  }

  /* Related Papers List */
  .related-papers-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 640px) {
    .related-papers-list {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .related-paper-item {
    background: var(--bg-app);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 0.75rem;
    transition: all 0.2s ease;
  }
  .related-paper-item:hover {
    border-color: var(--primary);
    transform: translateY(-2px);
    background: var(--bg-card);
    box-shadow: var(--shadow-sm);
  }
  .related-paper-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-main);
    line-height: 1.4;
  }
  .related-paper-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.75rem;
    color: var(--text-light);
  }
  .arxiv-id-label {
    font-family: monospace;
    background: var(--border);
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    color: var(--text-muted);
  }
  .related-paper-item:hover .arxiv-id-label {
    background: var(--primary-light);
    color: var(--primary);
  }

  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2.5rem;
    color: var(--text-light);
    text-align: center;
    gap: 0.5rem;
  }
  .empty-icon {
    color: var(--text-light);
    opacity: 0.5;
  }

  /* Cost Breakdown Dashboard */
  .cost-dashboard {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-top: 1rem;
  }
  @media (min-width: 768px) {
    .cost-dashboard {
      grid-template-columns: 2fr 3fr;
    }
  }
  .cost-summary-card {
    background: var(--primary-gradient);
    color: white;
    border-radius: 12px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }
  .cost-summary-card::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -50%;
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, rgba(255,255,255,0) 70%);
    border-radius: 50%;
  }
  .cost-summary-label {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.85;
    margin-bottom: 0.5rem;
  }
  .cost-summary-value {
    font-size: 2.25rem;
    font-weight: 800;
    font-family: monospace;
    line-height: 1;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }
  .cost-summary-sub {
    font-size: 0.85rem;
    opacity: 0.9;
  }
  .cost-summary-sub span {
    font-family: monospace;
    background: rgba(255,255,255,0.15);
    padding: 0.1rem 0.3rem;
    border-radius: 4px;
  }
  .cost-summary-badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    background: rgba(255,255,255,0.2);
    padding: 0.2rem 0.5rem;
    border-radius: 20px;
  }

  .cost-details-panel {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1.25rem;
  }
  .token-usage-bar {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .bar-track {
    height: 12px;
    background: var(--bg-app);
    border-radius: 6px;
    display: flex;
    overflow: hidden;
    border: 1px solid var(--border);
  }
  .bar-fill {
    height: 100%;
  }
  .input-fill {
    background-color: var(--primary);
  }
  .output-fill {
    background-color: var(--success);
  }
  .bar-legend {
    display: flex;
    gap: 1rem;
    font-size: 0.8rem;
    color: var(--text-light);
  }
  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }
  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    display: inline-block;
  }
  .input-dot {
    background-color: var(--primary);
  }
  .output-dot {
    background-color: var(--success);
  }

  .cost-breakdown-grid {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .cost-detail-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
    font-size: 0.9rem;
  }
  .cost-detail-row.total-row {
    border-bottom: none;
    font-weight: 700;
    color: var(--text-main);
  }
  .detail-label {
    color: var(--text-muted);
  }
  .detail-value {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .detail-value strong {
    font-family: monospace;
  }
  .detail-price {
    font-family: monospace;
    color: var(--text-light);
    font-size: 0.85rem;
    background: var(--bg-app);
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
  }

  /* Copy Code Block Button */
  .copy-code-btn {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    color: var(--text-muted);
    width: 28px;
    height: 28px;
    border-radius: 6px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.2s ease, background-color 0.2s ease;
    z-index: 10;
  }
  div:hover > .copy-code-btn {
    opacity: 1;
  }
  .copy-code-btn:hover {
    background: var(--primary-light);
    color: var(--primary);
    border-color: rgba(79, 70, 229, 0.2);
  }

  /* Footer Section */
  .footer {
    margin-top: 4rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    color: var(--text-light);
    font-size: 0.85rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .footer strong {
    color: var(--text-muted);
  }
  .footer code {
    font-family: monospace;
    background: var(--code-bg);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
  }
</style>
<script>
  window.MathJax = {
    tex: {
      inlineMath: [['$', '$'], ['\\(', '\\)']],
      displayMath: [['$$', '$$'], ['\\[', '\\]']],
      processEscapes: true,
      processEnvironments: true
    },
    options: {
      skipHtmlTags: ['script', 'noscript', 'style', 'textarea', 'pre']
    }
  };
</script>
<script src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-chtml.js" id="MathJax-script" defer></script>
