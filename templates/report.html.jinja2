<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ paper.title }} — ppagent Report</title>
<style>
  :root {
    --primary: #2563eb;
    --primary-dark: #1e40af;
    --text: #1f2937;
    --text-light: #6b7280;
    --bg: #ffffff;
    --bg-alt: #f9fafb;
    --border: #e5e7eb;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    max-width: 920px; margin: 0 auto; padding: 2rem 1.5rem;
    line-height: 1.7; color: var(--text); background: var(--bg);
  }
  h1 { font-size: 1.75rem; border-bottom: 3px solid var(--primary); padding-bottom: 0.75rem; margin-bottom: 1rem; }
  h2 { color: var(--primary-dark); margin-top: 2.5rem; margin-bottom: 0.75rem; font-size: 1.35rem; border-bottom: 1px solid var(--border); padding-bottom: 0.35rem; }
  h3 { color: var(--primary-dark); margin-top: 1.5rem; margin-bottom: 0.5rem; font-size: 1.1rem; }
  p { margin-bottom: 0.75rem; }
  blockquote {
    border-left: 4px solid var(--primary); margin: 1rem 0; padding: 0.75rem 1rem;
    background: var(--bg-alt); border-radius: 0 6px 6px 0; color: var(--text-light);
  }
  table { border-collapse: collapse; width: 100%; margin: 1rem 0; }
  th, td { border: 1px solid var(--border); padding: 0.5rem 0.75rem; text-align: left; }
  th { background: var(--bg-alt); font-weight: 600; }
  ul, ol { margin: 0.5rem 0 0.75rem 1.5rem; }
  li { margin-bottom: 0.25rem; }
  a { color: var(--primary); text-decoration: none; }
  a:hover { text-decoration: underline; }
  hr { border: none; border-top: 1px solid var(--border); margin: 2rem 0; }
  code { background: var(--bg-alt); padding: 0.15rem 0.35rem; border-radius: 3px; font-size: 0.9em; }
  pre { background: var(--bg-alt); padding: 1rem; border-radius: 6px; overflow-x: auto; margin: 1rem 0; }
  pre code { background: none; padding: 0; }
  .footer { margin-top: 3rem; padding-top: 1rem; border-top: 1px solid var(--border); color: var(--text-light); font-size: 0.85rem; }
  .meta-table { font-size: 0.95rem; }
  .severity-high { color: #dc2626; font-weight: 700; }
  .severity-medium { color: #d97706; font-weight: 600; }
  .severity-low { color: #6b7280; }
</style>
</head>
<body>

<h1>{{ paper.title }}</h1>

<blockquote><strong>TL;DR</strong>: {{ tldr.content }}</blockquote>

<table class="meta-table">
  <tr><th>Field</th><th>Value</th></tr>
  <tr><td><strong>Paper</strong></td><td><a href="{{ paper.arxiv_url }}">arXiv:{{ paper.id }}</a></td></tr>
  <tr><td><strong>HuggingFace</strong></td><td><a href="{{ paper.hf_url }}">Link</a></td></tr>
  <tr><td><strong>Published</strong></td><td>{{ paper.published_at.strftime('%Y-%m-%d') if paper.published_at else 'Unknown' }}</td></tr>
  <tr><td><strong>Authors</strong></td><td>{{ paper.authors | join(', ') }}</td></tr>
  <tr><td><strong>Affiliations</strong></td><td>{{ affiliations | join(', ') or 'N/A' }}</td></tr>
  <tr><td><strong>Keywords</strong></td><td>{{ keywords | join(', ') or 'N/A' }}</td></tr>
</table>

<h2>Benchmarks</h2>
<p>{{ benchmarks.content }}</p>

<h2>Previous Work &amp; Limitations</h2>
<p>{{ previous_works.content }}</p>

{% if finder_narrative %}
<h3>Related Work Landscape</h3>
<p>{{ finder_narrative }}</p>
{% endif %}

<h2>Method</h2>
<p>{{ method.content }}</p>

<h2>Performance Evaluation</h2>
<p>{{ evaluation.content }}</p>

<h2>Critical Analysis</h2>
<p>{{ critique.content }}</p>

<h2>Related Papers</h2>
{% if related_works %}
<ul>
{% for rp in related_works %}
  <li><a href="{{ rp.arxiv_url }}">{{ rp.title }}</a> ({{ rp.id }})</li>
{% endfor %}
</ul>
{% else %}
<p>No related papers found.</p>
{% endif %}

<div class="footer">
  Generated by <strong>ppagent</strong> on {{ generated_at.strftime('%Y-%m-%d %H:%M') }} using {{ model_used }}
</div>

</body>
</html>
